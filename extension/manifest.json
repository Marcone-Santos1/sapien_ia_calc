{
  "manifest_version": 3,
  "name": "Sapienia - Resolutor de Questões IA",
  "version": "1.0.0",
  "description": "Selecione uma área da tela ou cole o texto para que a IA resolva e explique detalhadamente a questão.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://sapienia.calculadoraunivesp.com.br/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Abrir Resolutor Sapienia"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
